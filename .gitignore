# ==========================================
# Logs
# ==========================================
logs/*.log
backup/logs/*.log
deployment/deployment.log

# Keep the folders in Git
!logs/.gitkeep
!backup/logs/.gitkeep

# ==========================================
# Environment Variables
# ==========================================
.env
.env.*

# ==========================================
# SSH Keys
# ==========================================
*.pem
*.ppk

# ==========================================
# Linux Temporary Files
# ==========================================
*.swp
*.swo
*~
.cache/

# ==========================================
# macOS Files
# ==========================================
.DS_Store

# ==========================================
# Windows Files
# ==========================================
Thumbs.db
Desktop.ini

# ==========================================
# VS Code
# ==========================================
.vscode/

# ==========================================
# JetBrains IDE
# ==========================================
.idea/

# ==========================================
# Runtime Files
# ==========================================
*.pid
*.pid.lock

# ==========================================
# Archives
# ==========================================
*.zip
*.tar
*.tar.gz
*.gz

# ==========================================
# Backup Files
# ==========================================
*.bak
*.old
*.tmp

# ==========================================
# Python Cache (if used later)
# ==========================================
__pycache__/
*.pyc

# ==========================================
# Node Modules (if used later)
# ==========================================
node_modules/

# ==========================================
# Terraform (Future Enhancement)
# ==========================================
.terraform/
*.tfstate
*.tfstate.*

# ==========================================
# AWS CLI Credentials
# ==========================================
.aws/

# ==========================================
# Local Test Files
# ==========================================
test/
testing/
